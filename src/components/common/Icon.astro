---
interface Props {
  name:
    | 'terminal'
    | 'crosshair'
    | 'activity'
    | 'zap'
    | 'shield'
    | 'cpu'
    | 'gauge'
    | 'settings'
    | 'message'
    | 'whatsapp'
    | 'chevron';
  class?: string;
}

const { name, class: className = 'size-6' } = Astro.props;
---

{
  name === 'terminal' && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="M4 17h16M7 7h10M8 12h8" /></svg>
  )
}
{
  name === 'crosshair' && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="12" cy="12" r="8" />
      <circle cx="12" cy="12" r="2" />
      <path d="M12 2v4M12 18v4M2 12h4M18 12h4" />
    </svg>
  )
}
{
  name === 'activity' && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12h4l2-5 4 10 2-5h6" /></svg>
  )
}
{
  name === 'zap' && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z" /></svg>
  )
}
{
  name === 'shield' && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 3l7 3v5c0 5-3.5 8.5-7 10-3.5-1.5-7-5-7-10V6l7-3z" />
      <path d="M12 8v5M12 16h.01" />
    </svg>
  )
}
{
  name === 'cpu' && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="M4 8h16M6 12h12M8 16h8M5 5h14v14H5z" /></svg>
  )
}
{
  name === 'gauge' && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="M5 18h14M7 18V9l5-4 5 4v9M12 11v4" /></svg>
  )
}
{
  name === 'settings' && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M18.4 5.6l-2.8 2.8M8.4 15.6l-2.8 2.8" />
    </svg>
  )
}
{
  name === 'message' && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true">
      <path d="M20 11.5A8.5 8.5 0 0 1 7.6 19l-3.6 1 1-3.5A8.5 8.5 0 1 1 20 11.5z" />
      <path d="M9.3 8.8c.2-.4.4-.4.6-.4h.5c.2 0 .4 0 .6.4l.7 1.8c.1.2 0 .5-.1.7l-.4.5c-.1.1-.2.3 0 .5.4.8 1.1 1.6 1.9 2.1.2.1.4.1.6 0l.6-.4c.2-.1.4-.2.7-.1l1.7.7c.4.2.4.3.4.6v.5c0 .2 0 .4-.4.6-.5.3-1.1.5-1.7.5-2 0-4.1-1.5-5.3-2.8-1.2-1.3-2.5-3.1-2.5-5.1 0-.6.1-1.2.5-1.7z" />
    </svg>
  )
}
{
  name === 'whatsapp' && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true">
      <path
        fill="currentColor"
        stroke="none"
        d="M12 4.2a7.8 7.8 0 0 0-6.74 11.73L4.2 19.8l3.97-1.04A7.8 7.8 0 1 0 12 4.2zm0 1.55a6.25 6.25 0 0 1 5.38 9.44 6.24 6.24 0 0 1-7.18 2.83l-.36-.11-2.35.61.63-2.28-.13-.37A6.25 6.25 0 0 1 12 5.75zm-2.1 2.87c-.18 0-.47.07-.73.35-.25.28-.96.94-.96 2.29 0 1.34.98 2.64 1.11 2.82.13.18 1.88 3.01 4.64 4.09 2.29.9 2.76.72 3.26.67.5-.05 1.6-.65 1.82-1.28.23-.63.23-1.17.16-1.28-.06-.11-.24-.17-.5-.3-.25-.12-1.5-.74-1.73-.83-.23-.08-.39-.12-.56.12-.17.24-.65.82-.8.98-.14.17-.3.19-.55.07-.25-.13-1.06-.39-2.02-1.24-.74-.66-1.25-1.49-1.4-1.74-.14-.24-.01-.38.11-.5.11-.11.25-.3.38-.44.13-.14.17-.24.25-.4.09-.17.05-.32-.01-.45-.06-.12-.56-1.4-.79-1.9-.18-.45-.36-.47-.5-.48h-.43z"
