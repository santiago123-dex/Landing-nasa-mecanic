---
import { heroHighlights, trustStats, whatsappUrl } from '../../data/site';

const reveal = 'opacity-0 translate-y-8 transition duration-700 ease-out';
---

<section
  id="inicio"
  class="mx-auto grid min-h-[calc(100vh-5.5rem)] max-w-[1480px] gap-8 py-6 sm:py-8 md:gap-10 lg:py-10 xl:min-h-[calc(100vh-6.1rem)] xl:grid-cols-[minmax(0,1.03fr)_minmax(0,0.87fr)] xl:items-center xl:gap-12 xl:py-14"
>
  <div data-reveal class={`${reveal} flex max-w-[48rem] flex-col items-start md:mx-auto md:items-center md:text-center xl:mx-0 xl:items-start xl:text-left`}>
    <span class="mb-5 inline-flex items-center gap-2 rounded-full border border-[#f3d7db] bg-[#fff3f4] px-4 py-2 text-[0.68rem] font-bold uppercase tracking-[0.16em] text-nasa-accent sm:mb-7 sm:text-[0.74rem]">
      <svg class="size-4" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M3 12h4l2-5 4 10 2-5h6" />
        <path d="M18 5v4M16 7h4" />
      </svg>
      Ingenieria automotriz premium
    </span>

    <h1 class="m-0 max-w-[14ch] font-display text-[clamp(2.4rem,8.4vw,5.9rem)] leading-[0.96] font-bold tracking-[-0.065em] text-nasa-text">
      Tu vehiculo merece
      <span class="block bg-linear-to-r from-nasa-accent to-nasa-accent-strong bg-clip-text text-transparent">precision profesional</span>
    </h1>

    <p class="mt-5 max-w-[44rem] text-[1rem] leading-[1.75] text-nasa-muted sm:mt-7 sm:text-[1.06rem] md:text-[1.1rem] xl:text-[1.2rem]">
      Combinamos experiencia tecnica, criterio mecanico y procesos claros para que manejes con tranquilidad. Mas que reparar, optimizamos rendimiento, seguridad y confiabilidad.
    </p>

    <div class="mt-6 flex w-full flex-wrap gap-2.5 sm:mt-7 sm:gap-3 md:justify-center xl:justify-start">
      {heroHighlights.map((item) => (
        <span class="rounded-full border border-nasa-outline bg-white px-4 py-2 text-xs font-semibold text-slate-600 shadow-[0_6px_16px_rgba(14,22,40,0.06)]">{item}</span>
      ))}
    </div>

    <div class="mt-8 flex w-full flex-col gap-3 sm:mt-9 sm:flex-row sm:flex-wrap sm:gap-4 md:w-auto md:justify-center xl:justify-start">
      <a
        href={whatsappUrl}
        class="inline-flex min-h-12 w-full items-center justify-center rounded-full bg-nasa-accent px-7 py-3.5 text-sm font-bold text-white shadow-[0_16px_28px_rgba(190,47,60,0.24)] transition hover:-translate-y-0.5 hover:bg-nasa-accent-strong hover:shadow-[0_20px_34px_rgba(190,47,60,0.3)] sm:w-auto sm:px-8 sm:py-4 sm:text-base"
      >
        Agendar diagnostico
      </a>
      <a
        href="#servicios"
        class="inline-flex min-h-12 w-full items-center justify-center rounded-full border border-nasa-outline bg-white px-7 py-3.5 text-sm font-bold text-nasa-text transition hover:border-slate-300 hover:bg-slate-50 sm:w-auto sm:px-8 sm:py-4 sm:text-base"
      >
        Ver servicios
      </a>
    </div>
  </div>

  <div data-reveal style="transition-delay:120ms" class={`${reveal} relative mx-auto w-full max-w-[34rem] justify-self-stretch md:max-w-[31rem] xl:mx-0 xl:max-w-[43rem] xl:justify-self-end`}>
    <div class="section-shell relative aspect-[1.18/1] w-full overflow-hidden rounded-[2rem] p-3 sm:p-4">
      <div class="relative h-full w-full overflow-hidden rounded-[1.35rem]">
        <div class="absolute inset-0 z-10 bg-linear-to-t from-[#0d1730]/35 to-transparent"></div>
      <img
        src="/WhatsApp Image 2026-03-21 at 6.06.44 PM.jpeg"
        alt="Vehiculo atendido en NASA Auto Lab"
          class="h-full w-full object-cover object-[center_46%]"
      />
        <div class="absolute right-3 bottom-3 z-20 rounded-2xl bg-black/45 px-4 py-3 text-white backdrop-blur sm:right-4 sm:bottom-4">
          <p class="text-[10px] font-semibold uppercase tracking-[0.17em] text-white/70">Evaluacion inicial</p>
          <p class="mt-1 text-sm font-semibold sm:text-base">Diagnostico claro, decision informada</p>
        </div>
      </div>
    </div>

    <div class="mt-4 grid grid-cols-3 gap-3 sm:mt-5">
      {trustStats.map((item) => (
        <article class="glass-panel rounded-2xl p-3 text-center sm:p-4">
          <p class="font-display text-[1.2rem] leading-none font-bold text-nasa-text sm:text-[1.5rem]">{item.value}</p>
          <p class="mt-1 text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">{item.label}</p>
        </article>
      ))}
    </div>
  </div>
</section>
