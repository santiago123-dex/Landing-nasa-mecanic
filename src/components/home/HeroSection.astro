---
import { whatsappUrl } from '../../data/site';

const reveal = 'opacity-0 translate-y-8 transition duration-700 ease-out';
---

<section
  id="inicio"
  class="mx-auto grid min-h-[calc(100vh-5.5rem)] max-w-[1440px] gap-8 py-6 sm:py-10 md:gap-10 lg:gap-12 xl:min-h-[calc(100vh-6.5rem)] xl:grid-cols-[minmax(0,1fr)_minmax(0,0.92fr)] xl:items-center xl:py-14 2xl:max-w-[1500px] 2xl:grid-cols-[minmax(0,1.02fr)_minmax(0,0.98fr)]"
>
  <div data-reveal class={`${reveal} flex max-w-[42rem] flex-col items-start xl:pl-4 2xl:pl-10`}>
    <span class="mb-6 inline-flex items-center gap-2 rounded-full bg-[#fcf2f2] px-3 py-2 text-[0.64rem] font-bold uppercase tracking-[0.16em] text-[#b83737] sm:mb-8 sm:px-4 sm:text-[0.72rem] sm:tracking-[0.18em]">
      <svg class="size-4" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M3 12h4l2-5 4 10 2-5h6" />
        <path d="M18 5v4M16 7h4" />
      </svg>
      Excelencia automotriz
    </span>

    <h1 class="m-0 text-[clamp(2.55rem,14vw,5.8rem)] leading-[0.92] tracking-[-0.08em] text-[#b83737] sm:text-[clamp(3.3rem,8vw,5.8rem)] xl:text-[clamp(4.4rem,5.2vw,6.1rem)]">
      <span class="block font-display font-bold uppercase">NASA</span>
      <span class="mt-2 block text-[clamp(1.95rem,9vw,4.2rem)] font-light italic text-slate-500 sm:text-[clamp(2.5rem,6vw,4.2rem)] xl:text-[clamp(2.9rem,3.8vw,4.45rem)]">Auto Lab</span>
    </h1>

    <p class="mt-6 max-w-[34rem] text-[0.98rem] leading-[1.75] text-slate-500 sm:mt-7 sm:text-[1.08rem] md:text-[1.16rem] xl:mt-8 xl:text-[1.3rem] xl:leading-[1.72]">
      Ingenieria de excelencia y rigor profesional, con un equipo en constante formacion para proteger y optimizar tu vehiculo con integridad, garantizando un rendimiento de alta calidad.
    </p>

    <div class="mt-8 flex w-full flex-col gap-3 sm:mt-10 sm:flex-row sm:gap-4 xl:mt-11">
      <a
        href={whatsappUrl}
        class="inline-flex w-full items-center justify-center rounded-full bg-[#b83737] px-6 py-3.5 text-sm font-bold text-white shadow-[0_14px_24px_rgba(184,55,55,0.16)] transition hover:-translate-y-0.5 hover:bg-[#a93232] sm:w-auto sm:px-8 sm:py-4 sm:text-base"
      >
        Agendar Cita
      </a>
      <a
        href="#servicios"
        class="inline-flex w-full items-center justify-center rounded-full border border-slate-200 bg-white px-6 py-3.5 text-sm font-bold text-nasa-text transition hover:border-slate-300 hover:bg-slate-50 sm:w-auto sm:px-8 sm:py-4 sm:text-base"
      >
        Nuestros Servicios
      </a>
    </div>
  </div>

  <div data-reveal style="transition-delay:120ms" class={`${reveal} relative mx-auto w-full max-w-[56rem] justify-self-stretch xl:mx-0 xl:max-w-[42rem] xl:justify-self-end 2xl:max-w-[48rem]`}>
    <div class="aspect-[1.08/1] w-full overflow-hidden rounded-[2rem] shadow-[0_28px_60px_rgba(15,23,42,0.18)] sm:aspect-[1.18/1] sm:rounded-[2.5rem] xl:aspect-[1.12/1] 2xl:aspect-[1.1/1]">
      <img
        src="/WhatsApp Image 2026-03-21 at 6.06.44 PM.jpeg"
        alt="Vehiculo atendido en NASA Auto Lab"
        class="h-full w-full object-cover object-center"
      />
    </div>
    <div class="absolute right-3 bottom-3 grid grid-cols-4 gap-1.5 rounded-2xl bg-white/90 p-2.5 shadow-[0_20px_50px_rgba(15,23,42,0.12)] sm:bottom-[-1rem] sm:left-[-1rem] sm:right-auto sm:gap-2 sm:p-3 xl:left-[-0.75rem] xl:bottom-[-0.75rem]">
      {Array.from({ length: 12 }).map(() => <span class="size-2 rounded-full bg-[#e7b4b4]"></span>)}
    </div>
  </div>
</section>
