---
import { whatsappUrl } from '../../data/site';

const reveal = 'opacity-0 translate-y-8 transition duration-700 ease-out';
---

<section
  id="inicio"
  class="mx-auto grid min-h-[calc(100vh-5.5rem)] max-w-[1380px] gap-7 py-5 sm:py-8 md:gap-8 md:py-9 lg:gap-10 xl:min-h-[calc(100vh-6.5rem)] xl:grid-cols-[minmax(0,1fr)_minmax(0,0.84fr)] xl:items-center xl:py-14 2xl:max-w-[1440px] 2xl:grid-cols-[minmax(0,1.03fr)_minmax(0,0.9fr)]"
>
  <div data-reveal class={`${reveal} flex max-w-[42rem] flex-col items-start md:mx-auto md:items-center md:text-center lg:mx-0 lg:items-start lg:text-left lg:max-w-[34rem] xl:pl-4 2xl:pl-10`}>
    <span class="mb-5 inline-flex items-center gap-2 rounded-full bg-[#fcf2f2] px-3 py-2 text-[0.62rem] font-bold uppercase tracking-[0.15em] text-[#b83737] sm:mb-7 sm:px-4 sm:text-[0.72rem] sm:tracking-[0.18em]">
      <svg class="size-4" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M3 12h4l2-5 4 10 2-5h6" />
        <path d="M18 5v4M16 7h4" />
      </svg>
      Excelencia automotriz
    </span>

    <h1 class="m-0 text-[clamp(2.35rem,12vw,5.8rem)] leading-[0.94] tracking-[-0.07em] text-[#b83737] sm:text-[clamp(3rem,8vw,5.6rem)] md:text-[clamp(3.2rem,7vw,5.4rem)] xl:text-[clamp(4.4rem,5.2vw,6.1rem)]">
      <span class="block font-display font-bold uppercase">NASA</span>
      <span class="mt-2 block text-[clamp(1.72rem,7vw,4.2rem)] font-light italic text-slate-500 sm:text-[clamp(2.2rem,5.8vw,4rem)] md:text-[clamp(2.25rem,5vw,3.8rem)] xl:text-[clamp(2.9rem,3.8vw,4.45rem)]">Auto Lab</span>
    </h1>

    <p class="mt-5 max-w-[34rem] text-[0.95rem] leading-[1.72] text-slate-500 sm:mt-6 sm:text-[1.04rem] md:max-w-[40rem] md:text-[1.08rem] xl:mt-8 xl:text-[1.3rem] xl:leading-[1.72]">
      Ingenieria de excelencia y rigor profesional, con un equipo en constante formacion para proteger y optimizar tu vehiculo con integridad, garantizando un rendimiento de alta calidad.
    </p>

    <div class="mt-7 flex w-full flex-col gap-3 sm:mt-8 sm:flex-row sm:flex-wrap sm:gap-4 md:w-auto md:justify-center xl:mt-11">
      <a
        href={whatsappUrl}
        class="inline-flex min-h-12 w-full items-center justify-center rounded-full bg-[#b83737] px-6 py-3.5 text-sm font-bold text-white shadow-[0_14px_24px_rgba(184,55,55,0.16)] transition hover:-translate-y-0.5 hover:bg-[#a93232] sm:w-auto sm:px-8 sm:py-4 sm:text-base"
      >
        Agendar Cita
      </a>
      <a
        href="#servicios"
        class="inline-flex min-h-12 w-full items-center justify-center rounded-full border border-slate-200 bg-white px-6 py-3.5 text-sm font-bold text-nasa-text transition hover:border-slate-300 hover:bg-slate-50 sm:w-auto sm:px-8 sm:py-4 sm:text-base"
      >
        Nuestros Servicios
      </a>
    </div>
  </div>

  <div data-reveal style="transition-delay:120ms" class={`${reveal} relative mx-auto w-full max-w-[34rem] justify-self-stretch md:max-w-[32rem] xl:mx-0 xl:max-w-[35rem] xl:justify-self-end 2xl:max-w-[39rem]`}>
    <div class="aspect-[1.26/1] w-full overflow-hidden rounded-[1.85rem] shadow-[0_24px_52px_rgba(15,23,42,0.16)] sm:aspect-[1.3/1] sm:rounded-[2.2rem] md:aspect-[1.36/1] xl:aspect-[1.16/1] 2xl:aspect-[1.14/1]">
      <img
        src="/WhatsApp Image 2026-03-21 at 6.06.44 PM.jpeg"
        alt="Vehiculo atendido en NASA Auto Lab"
        class="h-full w-full object-cover object-[center_46%]"
      />
    </div>
    <div class="absolute right-3 bottom-3 grid grid-cols-4 gap-1.5 rounded-2xl bg-white/90 p-2 shadow-[0_18px_40px_rgba(15,23,42,0.12)] sm:bottom-[-0.75rem] sm:left-[-0.75rem] sm:right-auto sm:gap-2 sm:p-2.5 xl:left-[-0.75rem] xl:bottom-[-0.75rem]">
      {Array.from({ length: 12 }).map(() => <span class="size-1.5 rounded-full bg-[#e7b4b4] sm:size-2"></span>)}
    </div>
  </div>
</section>
