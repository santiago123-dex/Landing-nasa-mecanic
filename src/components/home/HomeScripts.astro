<script>
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-8');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 },
  );

  document.querySelectorAll('[data-reveal]').forEach((node) => revealObserver.observe(node));

  const menuToggle = document.querySelector('[data-menu-toggle]');
  const mobileNav = document.querySelector('[data-mobile-nav]');

  menuToggle?.addEventListener('click', () => {
    const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
    menuToggle.setAttribute('aria-expanded', String(!expanded));
    mobileNav?.classList.toggle('hidden', expanded);
    mobileNav?.classList.toggle('flex', !expanded);
  });

  mobileNav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menuToggle?.setAttribute('aria-expanded', 'false');
      mobileNav?.classList.add('hidden');
      mobileNav?.classList.remove('flex');
    });
  });

  const track = document.querySelector('[data-services-track]');
  const viewport = document.querySelector('[data-services-viewport]');
  const prevButton = document.querySelector('[data-services-prev]');
  const nextButton = document.querySelector('[data-services-next]');
  const dots = Array.from(document.querySelectorAll('[data-services-dot]'));

  if (track instanceof HTMLElement && viewport instanceof HTMLElement) {
    let currentIndex = 0;
    const cards = Array.from(track.children);
    let startX = 0;
    let currentX = 0;
    let isDragging = false;
    let pointerId = -1;

    const getVisibleCards = () => {
      if (window.innerWidth >= 1280) return 3;
      if (window.innerWidth >= 768) return 2;
      return 1;
    };

    const getMaxIndex = () => Math.max(dots.length - getVisibleCards(), 0);
    const getCardMetrics = () => {
      const card = cards[0];
      const gap = 24;
      const cardWidth = card instanceof HTMLElement ? card.getBoundingClientRect().width : 0;
      return { gap, cardWidth };
    };
    const getOffsetForIndex = (index: number) => {
      const { gap, cardWidth } = getCardMetrics();
      return index * (cardWidth + gap);
    };

    const renderSlider = () => {
      currentIndex = Math.min(currentIndex, getMaxIndex());
      const offset = getOffsetForIndex(currentIndex);
      track.style.transform = `translateX(-${offset}px)`;

      dots.forEach((dot, index) => {
        const active = index === currentIndex;
        dot.classList.toggle('bg-nasa-accent', active);
        dot.classList.toggle('bg-slate-300', !active);
      });

      prevButton?.toggleAttribute('disabled', currentIndex === 0);
      nextButton?.toggleAttribute('disabled', currentIndex >= getMaxIndex());
      prevButton?.classList.toggle('opacity-40', currentIndex === 0);
      nextButton?.classList.toggle('opacity-40', currentIndex >= getMaxIndex());
    };
    const clampDragOffset = (dragOffset: number) => {
      const minOffset = -getOffsetForIndex(getMaxIndex());
      const maxOffset = 0;
      return Math.min(maxOffset, Math.max(minOffset, dragOffset));
    };
    const renderDrag = () => {
      const baseOffset = getOffsetForIndex(currentIndex);
      const dragOffset = clampDragOffset(-baseOffset + (currentX - startX));
      track.style.transform = `translateX(${dragOffset}px)`;
    };

    prevButton?.addEventListener('click', () => {
      currentIndex = Math.max(currentIndex - 1, 0);
      renderSlider();
    });

    nextButton?.addEventListener('click', () => {
      currentIndex = Math.min(currentIndex + 1, getMaxIndex());
      renderSlider();
    });

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        currentIndex = Math.min(index, getMaxIndex());
        renderSlider();
      });
    });

    viewport.addEventListener('pointerdown', (event) => {
      if (window.innerWidth >= 768) return;
      if (!event.isPrimary) return;

      isDragging = true;
      pointerId = event.pointerId;
      startX = event.clientX;
      currentX = event.clientX;
      track.style.transitionDuration = '0ms';
      viewport.setPointerCapture(pointerId);
    });

    viewport.addEventListener('pointermove', (event) => {
      if (!isDragging || event.pointerId !== pointerId) return;
      currentX = event.clientX;
      renderDrag();
    });

    const endDrag = (event: PointerEvent) => {
      if (!isDragging || event.pointerId !== pointerId) return;

      const deltaX = currentX - startX;
      const threshold = 50;

      isDragging = false;
      pointerId = -1;
      track.style.transitionDuration = '';

      if (Math.abs(deltaX) > threshold) {
        if (deltaX < 0) {
          currentIndex = Math.min(currentIndex + 1, getMaxIndex());
        } else {
          currentIndex = Math.max(currentIndex - 1, 0);
        }
      }

      renderSlider();
    };

    viewport.addEventListener('pointerup', endDrag);
    viewport.addEventListener('pointercancel', endDrag);

    window.addEventListener('resize', renderSlider);
    renderSlider();
  }
</script>
