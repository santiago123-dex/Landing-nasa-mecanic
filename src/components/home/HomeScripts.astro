<script>
  const bootScreen = document.querySelector('#boot-screen');
  const siteShell = document.querySelector('#site-shell');
  const loadingPanel = document.querySelector('#services-loading');
  const servicesGrid = document.querySelector('#services-grid');
  const loadingValue = document.querySelector('#loading-progress-value');
  const loadingBar = document.querySelector('#loading-progress-bar');
  const rows = Array.from(document.querySelectorAll('[data-service-row]'));
  const whatsappButton = document.querySelector('#whatsapp-button');
  const menuToggle = document.querySelector('[data-menu-toggle]');
  const mobileNav = document.querySelector('[data-mobile-nav]');

  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-8');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 },
  );

  document.querySelectorAll('[data-reveal]').forEach((node) => revealObserver.observe(node));

  menuToggle?.addEventListener('click', () => {
    const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
    menuToggle.setAttribute('aria-expanded', String(!expanded));
    mobileNav?.classList.toggle('hidden', expanded);
    mobileNav?.classList.toggle('flex', !expanded);
  });

  mobileNav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menuToggle?.setAttribute('aria-expanded', 'false');
      mobileNav.classList.add('hidden');
      mobileNav.classList.remove('flex');
    });
  });

  window.setTimeout(() => {
    bootScreen?.classList.add('hidden');
    siteShell?.classList.remove('hidden');
  }, 2000);

  window.setTimeout(() => {
    let progress = 0;
    const interval = window.setInterval(() => {
      progress = Math.min(progress + 2, 100);
      if (loadingValue) loadingValue.textContent = `${progress}%`;
      if (loadingBar instanceof HTMLElement) loadingBar.style.width = `${progress}%`;

      if (progress >= 100) {
        window.clearInterval(interval);
        window.setTimeout(() => {
          loadingPanel?.classList.add('hidden');
          servicesGrid?.classList.remove('hidden');
          rows.forEach((row, index) => {
            window.setTimeout(() => {
              row.classList.remove('opacity-0', 'translate-y-6');
              row.classList.add('opacity-100', 'translate-y-0');
            }, index * 100);
          });
        }, 150);
      }
    }, 36);
  }, 2000);

  rows.forEach((row) => {
    const button = row.querySelector('[data-service-toggle]');
    const details = row.querySelector('[data-service-details]');
    const pluses = row.querySelectorAll('[data-plus]');
    const minuses = row.querySelectorAll('[data-minus]');
    const serviceId = row.querySelector('span');
    const desc = row.querySelector('p');

    button?.addEventListener('click', () => {
      const expanded = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', String(!expanded));

      row.classList.toggle('bg-zinc-950', !expanded);
      row.classList.toggle('text-white', !expanded);
      row.classList.toggle('border-zinc-950', !expanded);

      if (serviceId instanceof HTMLElement) {
        serviceId.classList.toggle('text-white/60', !expanded);
        serviceId.classList.toggle('text-black/50', expanded);
      }

      if (desc instanceof HTMLElement) {
        desc.classList.toggle('text-white/80', !expanded);
        desc.classList.toggle('text-black/60', expanded);
      }

      pluses.forEach((node) => node.classList.toggle('hidden', !expanded));
      minuses.forEach((node) => node.classList.toggle('hidden', expanded));

      if (details instanceof HTMLElement) details.classList.toggle('hidden', expanded);
    });
  });

  whatsappButton?.addEventListener('click', (event) => {
    event.preventDefault();
    if (whatsappButton.classList.contains('is-connecting')) return;

    const defaultNode = whatsappButton.querySelector('[data-whatsapp-default]');
    const loadingNode = whatsappButton.querySelector('[data-whatsapp-loading]');
    const spinnerNode = whatsappButton.querySelector('[data-whatsapp-spinner]');

    whatsappButton.classList.add('is-connecting', 'bg-nasa-accent');
    whatsappButton.classList.remove('bg-black');
    defaultNode?.classList.add('hidden');
    loadingNode?.classList.remove('hidden');
    loadingNode?.classList.add('inline-flex');
    spinnerNode?.classList.remove('hidden');

    window.setTimeout(() => {
      window.open(whatsappButton.getAttribute('href') || '#', '_blank', 'noopener,noreferrer');
      whatsappButton.classList.remove('is-connecting', 'bg-nasa-accent');
      whatsappButton.classList.add('bg-black');
      defaultNode?.classList.remove('hidden');
      loadingNode?.classList.add('hidden');
      loadingNode?.classList.remove('inline-flex');
      spinnerNode?.classList.add('hidden');
    }, 1200);
  });
</script>
