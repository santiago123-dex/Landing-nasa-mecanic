---
const hudText =
  'fixed inset-6 z-40 hidden pointer-events-none border border-black/10 p-4 font-mono text-[10px] font-bold uppercase tracking-[0.18em] text-black/45 md:flex md:flex-col md:justify-between';
---

<div class={hudText}>
  <div class="flex justify-between">
    <span class="text-black/70">NASA Auto Lab // OS v3.1.0</span>
    <span class="inline-flex items-center gap-2 text-nasa-accent">
      <span class="size-2 rounded-full bg-nasa-accent animate-pulse-soft"></span>
      SISTEMA EN LINEA
    </span>
  </div>
  <div class="flex justify-between">
    <span>COORD: 4.5339 N / 75.6811 W</span>
    <span>DESPLAZAR PARA NAVEGAR ↓</span>
  </div>
</div>
