---
import { pillars } from '../../data/site';

const reveal = 'opacity-0 translate-y-8 transition duration-700 ease-out';
---

<section
  id="nosotros"
  class="mt-12 border-t border-black/6 py-14 sm:mt-14 sm:py-16 xl:py-20"
>
  <div data-reveal class={`${reveal} mx-auto max-w-[68rem] text-center`}>
    <span class="inline-flex items-center gap-2 rounded-full border border-[#f3d7db] bg-[#fff3f4] px-4 py-2 text-[0.72rem] font-bold uppercase tracking-[0.16em] text-nasa-accent">
      <svg class="size-4" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M3 12h4l2-5 4 10 2-5h6" />
        <path d="M18 5v4M16 7h4" />
      </svg>
      Nosotros
    </span>

    <h2 class="mx-auto mt-7 mb-0 max-w-[16ch] font-display text-[clamp(2.1rem,8vw,4.7rem)] leading-[1.02] font-bold tracking-[-0.065em] text-nasa-text">
      Tecnologia, criterio y acompanamiento en cada servicio
    </h2>

    <p class="mx-auto mt-6 max-w-[56rem] text-[1rem] leading-[1.8] text-nasa-muted sm:text-[1.1rem] xl:text-[1.2rem]">
      En NASA Auto Lab construimos confianza con procesos claros, personal calificado y atencion centrada en resultados reales. Nuestro enfoque combina precision mecanica y comunicacion transparente.
    </p>
  </div>

  <div class="mt-11 grid gap-5 lg:grid-cols-[minmax(0,1.25fr)_minmax(0,1fr)] xl:mt-14 xl:gap-8">
    <article data-reveal class={`${reveal} section-shell overflow-hidden rounded-[2rem] p-3`}>
      <div class="relative overflow-hidden rounded-[1.35rem]">
        <img
          src="/WhatsApp Image 2026-03-21 at 6.06.45 PM (1).jpeg"
          alt="Equipo de trabajo en NASA Auto Lab"
          class="aspect-[1.15/1] w-full object-cover object-[center_40%]"
        />
        <div class="absolute inset-0 bg-linear-to-t from-[#0e1628]/45 to-transparent"></div>
        <div class="absolute right-4 bottom-4 left-4 flex flex-wrap gap-2">
          <span class="rounded-full bg-white/92 px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.12em] text-nasa-text">Diagnostico serio</span>
          <span class="rounded-full bg-white/92 px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.12em] text-nasa-text">Procesos claros</span>
        </div>
      </div>
    </article>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
      {pillars.map((pillar, index) => (
        <article
          data-reveal
          style={`transition-delay:${120 + index * 80}ms`}
          class={`${reveal} section-shell rounded-[1.5rem] p-6`}
        >
          <h3 class="m-0 font-display text-[1.45rem] font-bold tracking-[-0.05em] text-nasa-text">{pillar.title}</h3>
          <p class="mt-3 mb-0 text-[0.98rem] leading-[1.7] text-nasa-muted">{pillar.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
