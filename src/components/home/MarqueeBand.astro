---
import { marqueeItems } from '../../data/site';

const items = [...marqueeItems, ...marqueeItems];
---

<div
  data-reveal
  class="relative left-1/2 mt-8 mb-14 flex w-[100dvw] -translate-x-1/2 overflow-hidden border-y border-black/10 bg-nasa-surface py-3 opacity-0 transition duration-700 ease-out translate-y-8 md:mt-10 md:mb-20"
>
  <div class="flex w-max animate-marquee gap-8 whitespace-nowrap font-mono text-xs font-bold uppercase tracking-[0.18em] text-nasa-accent">
    {items.map((item) => (
      <>
        <span>{item}</span>
        <span>•</span>
      </>
    ))}
  </div>
</div>
