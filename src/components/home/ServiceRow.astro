---
import Icon from '../common/Icon.astro';

interface Props {
  id: string;
  title: string;
  desc: string;
  icon: 'activity' | 'zap' | 'crosshair' | 'shield';
  details: {
    time: string;
    tools: readonly string[];
    cost: string;
    link: string;
  };
}

const { id, title, desc, icon, details } = Astro.props;
---

<article
  data-service-row
  id={`protocolo-${id.toLowerCase().replace('.', '-')}`}
  class="border-b border-black/10 opacity-0 translate-y-6 transition duration-500 ease-out hover:bg-nasa-accent hover:text-white"
>
  <button
    type="button"
    data-service-toggle
    aria-expanded="false"
    class="group w-full cursor-pointer px-0 py-6 text-left sm:py-8 md:px-4"
  >
    <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-6 md:mr-8 md:gap-12">
        <span class="min-w-16 font-mono text-[11px] font-bold text-black/50 transition group-hover:text-white/60 md:text-xs">{id}</span>
        <h3 class="font-display text-lg font-bold uppercase tracking-[-0.04em] sm:text-xl md:text-3xl">{title}</h3>
      </div>

      <div class="flex flex-col gap-4 md:w-1/2 md:flex-row md:items-center md:justify-between">
        <p class="max-w-[34rem] font-mono text-[11px] leading-[1.8] font-medium text-black/60 transition group-hover:text-white/80 sm:text-xs">
          {desc}
        </p>

        <div class="hidden items-center gap-4 text-nasa-accent transition group-hover:text-white md:flex">
          <Icon name={icon} class="size-7" />
          <span data-plus class="font-display text-2xl font-bold">+</span>
          <span data-minus class="hidden font-display text-2xl font-bold">−</span>
        </div>
      </div>
    </div>

    <div class="mt-2 flex justify-end text-nasa-accent md:hidden">
      <span data-plus class="font-display text-2xl font-bold">+</span>
      <span data-minus class="hidden font-display text-2xl font-bold">−</span>
    </div>
  </button>

  <div data-service-details class="hidden overflow-hidden">
    <div class="grid gap-8 border-t border-white/20 py-6 sm:py-8 md:grid-cols-3 md:px-4">
      <div>
        <h4 class="mb-3 font-mono text-[10px] font-bold tracking-[0.18em] text-nasa-accent">TIEMPO ESTIMADO (T-MINUS)</h4>
        <p class="m-0 font-display text-3xl font-bold">{details.time}</p>

        <h4 class="mb-3 mt-6 font-mono text-[10px] font-bold tracking-[0.18em] text-nasa-accent">INVERSION ESTIMADA</h4>
        <p class="m-0 font-display text-2xl font-bold text-white/90">{details.cost}</p>
      </div>

      <div>
        <h4 class="mb-3 font-mono text-[10px] font-bold tracking-[0.18em] text-nasa-accent">INSTRUMENTAL REQUERIDO</h4>
        <ul class="m-0 grid list-none gap-3 p-0 font-mono text-xs text-white/80">
          {details.tools.map((tool) => (
            <li class="flex items-center gap-2">
              <span class="size-1 rounded-full bg-nasa-accent"></span>
              {tool}
            </li>
          ))}
        </ul>
      </div>

      <div class="flex items-end">
        <a class="inline-flex items-center gap-2 font-mono text-xs font-bold uppercase tracking-[0.16em] text-nasa-accent transition hover:text-white" href={details.link}>
          Ver Protocolo Completo
          <Icon name="chevron" class="size-4" />
        </a>
      </div>
    </div>
  </div>
</article>
