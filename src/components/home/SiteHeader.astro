---
import { navLinks, whatsappUrl } from '../../data/site';
---

<header
  data-reveal
  class="sticky top-0 z-30 -mx-4 mb-10 border-b border-black/8 bg-white/96 opacity-0 backdrop-blur transition duration-700 ease-out translate-y-8 sm:-mx-6 md:mb-16 lg:-mx-10"
>
  <div class="mx-auto w-full px-4 py-5 sm:px-6 lg:px-10">
    <div class="flex items-center justify-between gap-4">
      <a href="#inicio" class="flex items-center gap-3 text-nasa-text no-underline">
        <span class="grid size-9 place-items-center rounded-lg bg-nasa-accent text-white shadow-[0_10px_20px_rgba(239,12,24,0.25)]">
          <svg class="size-5" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 12h4l2-5 4 10 2-5h6" />
          </svg>
        </span>
        <span class="font-display text-[1.8rem] font-bold tracking-[-0.07em]">
          NASA<span class="text-black/55">.</span>LAB
        </span>
      </a>

      <nav class="hidden items-center gap-10 text-base font-semibold text-slate-600 lg:flex">
        {navLinks.map((link) => (
          <a class="transition hover:text-nasa-text" href={link.href}>{link.label}</a>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        <a
          href={whatsappUrl}
          class="hidden rounded-full bg-nasa-accent px-7 py-4 text-sm font-bold text-white shadow-[0_14px_24px_rgba(239,12,24,0.28)] transition hover:-translate-y-0.5 hover:shadow-[0_18px_30px_rgba(239,12,24,0.34)] sm:inline-flex"
        >
          Agendar Cita
        </a>

        <button
          type="button"
          data-menu-toggle
          aria-expanded="false"
          aria-controls="mobile-nav"
          class="grid size-11 place-items-center rounded-full border border-black/10 text-nasa-text lg:hidden"
        >
          <span class="sr-only">Abrir menu</span>
          <svg class="size-5" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </button>
      </div>
    </div>

    <nav
      id="mobile-nav"
      data-mobile-nav
      class="hidden flex-col gap-4 border-t border-black/8 pt-5 text-base font-semibold text-slate-600 lg:hidden"
    >
      {navLinks.map((link) => (
        <a class="transition hover:text-nasa-text" href={link.href}>{link.label}</a>
      ))}
      <a href={whatsappUrl} class="mt-1 inline-flex w-full justify-center rounded-full bg-nasa-accent px-6 py-3 text-sm font-bold text-white">
        Agendar Cita
      </a>
    </nav>
  </div>
</header>
