---
import { navLinks, whatsappUrl } from '../../data/site';
---

<header
  data-reveal
  class="sticky top-0 z-30 -mx-4 mb-8 border-b border-black/8 bg-white/96 opacity-0 backdrop-blur transition duration-700 ease-out translate-y-8 sm:-mx-6 md:mb-14 lg:-mx-8 xl:-mx-10"
>
  <div class="mx-auto w-full max-w-[1600px] px-4 py-4 sm:px-6 sm:py-5 lg:px-8 xl:px-10 2xl:px-12">
    <div class="flex items-center justify-between gap-4">
      <a href="#inicio" class="flex items-center gap-3 text-nasa-text no-underline">
        <img
          src="/LOGO TALLER NASA-02.png"
          alt="NASA Auto Lab"
          class="h-10 w-auto object-contain sm:h-11 md:h-10 lg:h-14 xl:h-16"
        />
      </a>

      <nav class="hidden items-center gap-6 text-sm font-semibold text-slate-600 xl:gap-8 xl:text-base 2xl:gap-10 lg:flex">
        {navLinks.map((link) => (
          <a class="transition hover:text-nasa-text" href={link.href}>{link.label}</a>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        <a
          href={whatsappUrl}
          class="hidden rounded-full bg-[#b83737] px-5 py-3 text-sm font-bold text-white shadow-[0_14px_24px_rgba(184,55,55,0.18)] transition hover:-translate-y-0.5 hover:bg-[#a93232] hover:shadow-[0_18px_30px_rgba(184,55,55,0.24)] lg:inline-flex xl:px-7 xl:py-4"
        >
          Agendar Cita
        </a>

        <button
          type="button"
          data-menu-toggle
          aria-expanded="false"
          aria-controls="mobile-nav"
          class="grid size-11 place-items-center rounded-full border border-black/10 text-nasa-text lg:hidden"
        >
          <span class="sr-only">Abrir menu</span>
          <svg class="size-5" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </button>
      </div>
    </div>

    <nav
      id="mobile-nav"
      data-mobile-nav
      class="hidden flex-col gap-4 border-t border-black/8 pt-5 text-base font-semibold text-slate-600 lg:hidden"
    >
      {navLinks.map((link) => (
        <a class="transition hover:text-nasa-text" href={link.href}>{link.label}</a>
      ))}
      <a href={whatsappUrl} class="mt-1 inline-flex w-full justify-center rounded-full bg-[#b83737] px-6 py-3 text-sm font-bold text-white">
        Agendar Cita
      </a>
    </nav>
  </div>
</header>
