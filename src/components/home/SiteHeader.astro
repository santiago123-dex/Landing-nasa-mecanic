---
import Icon from '../common/Icon.astro';
import { navLinks } from '../../data/site';
---

<header
  data-reveal
  class="mb-12 opacity-0 transition duration-700 ease-out translate-y-8 md:mb-20"
>
  <div class="flex items-center justify-between gap-6 border-b border-black/10 pb-6">
    <div class="inline-flex items-center gap-3 font-display text-2xl font-bold tracking-[-0.06em] md:text-3xl">
      <Icon name="crosshair" class="size-6 text-nasa-accent" />
      NASA
    </div>

    <nav class="hidden gap-8 font-mono text-xs font-bold uppercase tracking-[0.18em] text-black/60 md:flex">
      {navLinks.map((link) => (
        <a class="transition-colors hover:text-nasa-accent" href={link.href}>{link.label}</a>
      ))}
    </nav>

    <button
      type="button"
      data-menu-toggle
      aria-expanded="false"
      aria-controls="mobile-nav"
      class="border border-nasa-accent px-4 py-3 font-mono text-xs font-bold tracking-[0.18em] text-nasa-accent md:hidden"
    >
      MENU
    </button>
  </div>

  <nav
    id="mobile-nav"
    data-mobile-nav
    class="hidden flex-col gap-4 border-b border-black/10 py-4 font-mono text-xs font-bold uppercase tracking-[0.18em] text-black/60 md:hidden"
  >
    {navLinks.map((link) => (
      <a class="transition-colors hover:text-nasa-accent" href={link.href}>{link.label}</a>
    ))}
  </nav>
</header>
