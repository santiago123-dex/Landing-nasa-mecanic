---
import { siteMeta, whatsappUrl } from '../../data/site';

const reveal = 'opacity-0 translate-y-8 transition duration-700 ease-out';
---

<section
  id="contacto"
  class="mt-12 grid gap-7 border-t border-black/6 py-14 sm:py-16 lg:grid-cols-[minmax(320px,560px)_minmax(0,1fr)] xl:gap-10"
>
  <article data-reveal class={`${reveal} section-shell relative overflow-hidden rounded-[2rem] px-5 py-8 sm:rounded-[2.2rem] sm:px-8 sm:py-10 lg:px-9`}>
    <div class="pointer-events-none absolute right-4 bottom-3 text-[6rem] leading-none font-light text-slate-100 sm:right-8 sm:bottom-7 sm:text-[10rem]">∿</div>

    <div class="relative z-10">
      <div class="mx-auto flex max-w-[24rem] flex-col items-center text-center">
        <img
          src="/LOGO TALLER NASA N.png"
          alt="NASA Auto Lab"
          class="h-28 w-auto object-contain sm:h-40"
        />
        <p class="mt-6 mb-0 text-[0.98rem] leading-[1.8] text-nasa-muted sm:mt-8 sm:text-[1.08rem]">Agenda hoy y recibe una evaluacion profesional.</p>
        <p class="mt-4 mb-0 text-[1.2rem] font-bold tracking-[-0.05em] text-nasa-text sm:text-[1.7rem]">Estamos listos para atender tu vehiculo.</p>
        <a href={whatsappUrl} class="mt-5 inline-flex rounded-full bg-nasa-accent px-6 py-3 text-sm font-bold text-white shadow-[0_14px_26px_rgba(190,47,60,0.22)] transition hover:bg-nasa-accent-strong">
          Escribir por WhatsApp
        </a>
      </div>

      <div class="mt-10 space-y-6">
        <div class="flex items-start gap-4">
          <span class="grid size-12 shrink-0 place-items-center rounded-full bg-[#fff3f4] text-nasa-accent sm:size-13">
            <svg class="size-6" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20 11.5A8.5 8.5 0 0 1 7.6 19l-3.6 1 1-3.5A8.5 8.5 0 1 1 20 11.5z" />
            </svg>
          </span>
          <div class="min-w-0">
            <p class="m-0 text-xs font-bold uppercase tracking-[0.18em] text-slate-400">WhatsApp</p>
            <a href={whatsappUrl} class="mt-1 block break-words text-[1rem] font-bold tracking-[-0.04em] text-nasa-text sm:text-[1.35rem] lg:text-[1.45rem]">+57 323 366 1675</a>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <span class="grid size-12 shrink-0 place-items-center rounded-full bg-[#fff3f4] text-nasa-accent sm:size-13">
            <svg class="size-6" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 6h16v12H4z" />
              <path d="M4 7l8 6 8-6" />
            </svg>
          </span>
          <div class="min-w-0">
            <p class="m-0 text-xs font-bold uppercase tracking-[0.18em] text-slate-400">Correo</p>
            <a href="mailto:contacto@nasaautolab.com" class="mt-1 block break-words text-[0.98rem] leading-[1.45] font-bold tracking-[-0.04em] text-nasa-text sm:text-[1.25rem] lg:text-[1.4rem]">
              contacto@nasaautolab.com
            </a>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <span class="grid size-12 shrink-0 place-items-center rounded-full bg-[#fff3f4] text-nasa-accent sm:size-13">
            <svg class="size-6" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 21s7-5.7 7-11a7 7 0 1 0-14 0c0 5.3 7 11 7 11z" />
              <circle cx="12" cy="10" r="2.5" />
            </svg>
          </span>
          <div class="min-w-0">
            <p class="m-0 text-xs font-bold uppercase tracking-[0.18em] text-slate-400">Ubicacion</p>
            <p class="mt-1 text-[0.98rem] leading-[1.5] font-bold tracking-[-0.04em] text-nasa-text sm:text-[1.2rem] lg:text-[1.3rem]">{siteMeta.address}</p>
          </div>
        </div>
      </div>
    </div>
  </article>

  <div data-reveal style="transition-delay:120ms" class={`${reveal} section-shell overflow-hidden rounded-[2.2rem] p-3`}>
    <iframe
      src="https://maps.google.com/maps?q=Cl.%2015%20%2321A-03%2C%20Armenia%2C%20Quindio%2C%20Colombia&z=16&output=embed"
      title="Ubicacion de NASA Auto Lab"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      class="h-full min-h-[24rem] w-full rounded-[1.5rem] border-0 sm:min-h-[30rem]"
    ></iframe>
  </div>
</section>
