---
import Icon from '../common/Icon.astro';
---

<div id="boot-screen" class="grid min-h-screen place-items-center bg-nasa-bg px-8">
  <div class="animate-boot-fade flex flex-col items-center gap-4 text-center font-mono text-sm text-nasa-accent">
    <Icon name="terminal" class="size-10 animate-pulse-soft" />
    <p class="m-0 font-bold tracking-[0.12em]">&gt; INICIALIZANDO SISTEMAS NASA...</p>
    <div class="h-1 w-[min(16rem,70vw)] overflow-hidden bg-black/8">
      <div class="animate-boot-progress h-full origin-left bg-nasa-accent"></div>
    </div>
  </div>
</div>
